# changedetection.io
CHANGEDETECTION_URL=http://localhost:5000
CHANGEDETECTION_API_KEY=

# Demo test product
TEST_PRODUCT_URL=http://localhost:8088

# Orchestrator
ORCHESTRATOR_URL=http://localhost:8090
ORCHESTRATOR_WEBHOOK_SECRET=dev-secret-change-me

# Notifications (configure in changedetection UI or via API)
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Identity layer (CloakBrowser / proxies — optional for local demo)
CLOAKBROWSER_ENABLED=false
PROXY_POOL=http://user:pass@proxy1:8080,http://user:pass@proxy2:8080

# ASH meter stub
ASH_METER_STUB_BALANCE=1000

# LLM reasoning (required for console demo)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ASH_LLM_MODEL=gpt-4o-mini
ASH_MAX_AGENT_STEPS=8

# Set to 1 for CI/smoke without a real API key
# ASH_DEMO_MOCK=1
